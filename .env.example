# ForgeSight environment — copy to .env and fill in real values.
# NEVER commit .env. Rotate any key that has ever appeared in a doc or chat.

# --- Supabase (Postgres + Auth + Realtime) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_ANON_KEY=eyJhbGciOi...                 # anon JWT (browser-safe)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...         # server-only; never ships to client
SUPABASE_JWT_SECRET=<jwt-secret>                # HS256 secret for verifying Supabase JWTs
# Direct Postgres connection (pooled) for migrations / psycopg / langgraph checkpointer.
# Supabase: Project Settings -> Database -> Connection string (URI). Use the pooler host.
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# --- Models / synthesis backend (hybrid serving) ---
MODEL_BACKEND=slm_only                           # slm_only | hybrid
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct                 # local: swap to qwen-forgesight once fine-tuned + promoted
EMBED_MODEL=nomic-embed-text
# SYNTHESIS_BACKEND: "ollama" (local on-prem SLM, default) or "hosted" (cloud, no GPU → Groq).
SYNTHESIS_BACKEND=ollama
LLM_PROVIDER=groq                                # hosted fallback provider (groq | openai)
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=                                     # Groq/OpenAI key (only needed when SYNTHESIS_BACKEND=hosted)
RETRIEVAL_MODE=hybrid                            # hybrid (local Ollama embeddings) | fulltext (cloud, no embeddings)
HOSTED_LLM_API_KEY=                              # dev-time only (SFT gen / DeepEval)

# --- Observability / dev tools (optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
FIRECRAWL_API_KEY=                              # dev-time corpus seeding only (optional)
KAGGLE_USERNAME=                               # dataset download (optional)
KAGGLE_KEY=                                    # dataset download (optional)

# --- Flags ---
# DEMO_MODE=false → /chat runs the real governed pipeline (golden card is an error fallback only).
DEMO_MODE=false
# FR-7 background health scan inside the API lifespan (Railway: set ENABLE_SCHEDULER=true).
ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_SECONDS=120
